# Circuit Trader — environment template.
# Copy to .env.local (gitignored) and fill in. NEVER commit real keys.

# --- CoinMarketCap Agent Hub (MCP) ---
# Free Basic key at https://pro.coinmarketcap.com  (30 req/min, 10k credits/mo)
CMC_MCP_API_KEY=
# Override only if the endpoint changes:
# CMC_MCP_URL=https://mcp.coinmarketcap.com/mcp

# --- Trust Wallet Agent Kit (local MCP via `twak serve`) ---
# Install: curl -fsSL https://agent-kit.trustwallet.com/install.sh | bash   (then `twak setup`)
# Credentials (Access ID + HMAC Secret) from https://portal.trustwallet.com
# Either run `twak setup` (saves to OS keychain) OR set these and the connector forwards them:
TWAK_ACCESS_ID=
TWAK_HMAC_SECRET=
# For unattended VM workers, either save the password with
# `twak wallet keychain save --password <pw>` or set this env var.
# TWAK_WALLET_PASSWORD=
# Optional: explicit path to the twak binary if not on PATH
# TWAK_BIN=/home/youruser/.npm-global/bin/twak

# --- Dedicated agent wallet (BNB Smart Chain) ---
# Public address of the permissioned agent wallet. The PRIVATE KEY must live wherever
# the Agent Kit signs (its own config / a KMS) — NOT here, and NOT in the repo.
AGENT_WALLET_ADDRESS=

# Non-reserve assets scanned by the live runner. BNB is native; the connector includes
# default BSC addresses for USDT, USDC, ETH, CAKE, and TWT.
AGENT_ASSETS=BNB,TWT
AGENT_RESERVE_ASSET=USDT
AGENT_BASE_TRADE_USD=4
AGENT_MIN_STRENGTH=0.3
# Optional JSON override/additions, e.g. {"TOKEN":"0x..."}.
# AGENT_TOKEN_ADDRESSES={}

# --- Daily compliance round trip ---
# Track 1 requires at least one OPEN+CLOSE round trip per UTC day to stay ranked. When enabled,
# if no round trip has completed today, the runner does ONE minimal, net-flat round trip
# (sell→buy if the asset is held, else buy→sell). Each leg still passes the full constitution;
# only the anti-churn timing gates and concentration caps are waived (a round trip nets flat).
# Off by default. Size is the constitution's minTradeUsd.
COMPLIANCE_ENABLED=false
# Asset to round-trip (must be in the constitution allowlist, not the reserve). Defaults to AGENT_ASSETS[0].
# COMPLIANCE_ASSET=BNB
# Delay the round trip until this UTC hour (0-23), giving the strategy first chance to trade naturally.
COMPLIANCE_AFTER_UTC_HOUR=0

# --- Strategy reviewer ---
# Free/default mode uses the deterministic local reviewer. Set to "claude" only if you
# have an Anthropic key and want the LLM risk reviewer.
SYNTHESIZER_MODE=deterministic
# ANTHROPIC_API_KEY=

# --- Constitution (signed JSON). Use a local file for the VM runner or inline JSON. ---
CONSTITUTION_PATH=.circuit-trader/constitution.signed.json
# CONSTITUTION_JSON=
REQUIRE_SIGNED_CONSTITUTION=true
REQUIRE_CONSTITUTION_SIGNER_IS_WALLET=true
# Optional overrides applied while signing the example constitution.
# CONSTITUTION_MIN_TRADE_USD=0.1
# CONSTITUTION_MAX_TRADE_USD=0.2

# Signing uses the configured TWAK wallet by default. A raw key remains an optional fallback.
# CONSTITUTION_SIGNER_PRIVATE_KEY=

# --- VM/worker live runner ---
# Keep worker credentials in `.env.worker.local`; Vercel CLI owns `.env.local`.
RUNNER_STATE_PATH=.circuit-trader/state.json
RUNNER_TIMELINE_PATH=.circuit-trader/timeline.jsonl
RUNNER_JOURNAL_PATH=.circuit-trader/execution-journal.json
RUNNER_LOCK_PATH=.circuit-trader/runner.lock
RUNNER_INTERVAL_MS=900000
LIVE_DASHBOARD_URL=https://circuit-trader.vercel.app
# LIVE_INGEST_SECRET=

# --- Optional self-hosted Next API live route ---
# Keep disabled on Vercel; the live path needs a process that can spawn `twak serve`.
ENABLE_NEXT_API_LIVE_RUNNER=false
CRON_SECRET=
