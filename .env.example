# Circuit Trader — environment template.
# Copy to .env.local (gitignored) and fill in. NEVER commit real keys — route through Vercel env.

# --- CoinMarketCap Agent Hub (MCP) ---
# Free Basic key at https://pro.coinmarketcap.com  (30 req/min, 10k credits/mo)
CMC_MCP_API_KEY=
# Override only if the endpoint changes:
# CMC_MCP_URL=https://mcp.coinmarketcap.com/mcp

# --- Trust Wallet Agent Kit (MCP) ---
TWAK_MCP_URL=
TWAK_API_KEY=

# --- Dedicated agent wallet (BNB Smart Chain) ---
# Public address of the permissioned agent wallet. The PRIVATE KEY must live wherever
# the Agent Kit signs (its own config / a KMS) — NOT here, and NOT in the repo.
AGENT_WALLET_ADDRESS=

# --- Claude (LLM risk reviewer) ---
ANTHROPIC_API_KEY=

# --- Constitution (signed JSON). Either inline JSON or a path your loader reads. ---
# CONSTITUTION_JSON=

# --- Cron auth (Vercel Cron sends this; reject requests without it) ---
CRON_SECRET=
